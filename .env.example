# LLM Providers — add at least one
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=
XAI_API_KEY=
TOGETHER_API_KEY=
NVIDIA_API_KEY=
OPENCODE_API_KEY=

# Vision routing (optional — defaults to GROQ_API_KEY + qwen/qwen3.6-27b)
# When an image is attached, it's described by this vision model and the
# description is injected into the code model's prompt.
MANIAC_VISION_API_KEY=
MANIAC_VISION_MODEL=
MANIAC_VISION_BASE_URL=

# Telegram bidirectional bot (`maniac telegram`)
TELEGRAM_BOT_TOKEN=
# Required unless TELEGRAM_ALLOW_ALL=1 — comma-separated numeric ids and/or usernames
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_ALLOWED_USERNAMES=
# TELEGRAM_ALLOW_ALL=1   # open bot — not recommended
# TELEGRAM_POLL_TIMEOUT=25
# MANIAC_TELEGRAM_CWD=

# Optional HTTP secrets for http_request headers (only MANIAC_HTTP_SECRET_* allowed)
# MANIAC_HTTP_SECRET_FOO=...
# Then use header value: ${ENV:MANIAC_HTTP_SECRET_FOO}

# Crash recovery
# MANIAC_NO_AUTO_RESUME=1   # skip auto-resume on engine server startup
# MANIAC_RESUME_TOKEN=...   # required for /api/engine/immortality?action=execute_resume
# CLI: maniac --no-auto-resume

# Memory & storage (optional — defaults to ~/.maniac/)
MANIAC_MEMORY_DIR=
MANIAC_BRAIN_VAULT=

# MCP (optional)
MCP_CONFIG_PATH=
OPENCODE_CONFIG=

# Optional remote Windows exec bridge URL (disabled unless set)
MANIAC_WINDOWS_EXEC_BRIDGE=

# Service port (optional — default 3001)
PORT=3001
