# LLM Providers — add at least one
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=
XAI_API_KEY=
TOGETHER_API_KEY=
NVIDIA_API_KEY=
OPENCODE_API_KEY=

# Telegram (optional)
TELEGRAM_BOT_TOKEN=

# Memory & storage (optional — defaults to ~/.maniac/)
MANIAC_MEMORY_DIR=
MANIAC_BRAIN_VAULT=

# MCP (optional)
MCP_CONFIG_PATH=
OPENCODE_CONFIG=

# Optional remote Windows exec bridge URL (disabled unless set)
MANIAC_WINDOWS_EXEC_BRIDGE=

# Service port (optional — default 3001)
PORT=3001
